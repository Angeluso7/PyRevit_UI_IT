<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Editor de Parámetros" Height="450" Width="500"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanMinimize"
    >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Name="paramsListView" Grid.Row="0" Margin="0,0,0,10" 
                  IsSynchronizedWithCurrentItem="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Parámetro" Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Valor" Width="250" >
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Label Name="statusLabel" Grid.Row="1" Height="25" VerticalAlignment="Center"
               Content="Estado: listo" Margin="0,0,0,10" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="btnSave" Width="80" Margin="5" Content="Guardar"/>
            <Button Name="btnCancel" Width="80" Margin="5" Content="Cancelar"/>
        </StackPanel>
    </Grid>
</Window>








