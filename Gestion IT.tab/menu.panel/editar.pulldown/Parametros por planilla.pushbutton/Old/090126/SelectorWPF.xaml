<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selector Planilla"
        Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- TextBox filtro -->
            <RowDefinition Height="*"/>     <!-- ScrollViewer con planillas -->
            <RowDefinition Height="Auto"/>  <!-- Botón Aceptar -->
        </Grid.RowDefinitions>

        <!-- TextBox de filtro con evento -->
        <TextBox x:Name="FilterTextBox"
                 Grid.Row="0"
                 Margin="0,0,0,5"
                 TextChanged="OnFilterTextChanged" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PanelRBs"/>
        </ScrollViewer>

        <Button x:Name="AcceptButton"
                Grid.Row="2"
                Content="Aceptar"
                Height="30"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,5,0,0"/>
    </Grid>
</Window>







