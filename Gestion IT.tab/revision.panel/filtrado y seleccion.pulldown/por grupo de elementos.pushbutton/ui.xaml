<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    Title="Selección combinada" Height="700" Width="700" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Planilla -->
            <RowDefinition Height="*"/>      <!-- Elemento (desde CodIntBIM + diccionario) -->
            <RowDefinition Height="Auto"/>   <!-- Botón -->
        </Grid.RowDefinitions>

        <!-- Fila 0: Planillas -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Seleccione Planilla" FontWeight="Bold"/>
            <TextBox Name="PlanillasFilterBox" Margin="0,0,0,5" />
            <ScrollViewer Height="150">
                <ItemsControl Name="PlanillasList"/>
            </ScrollViewer>
        </StackPanel>

        <!-- Fila 1: Elementos (claves de codigos_elementos) -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Seleccione elemento" FontWeight="Bold"/>
            <TextBox Name="ElementosFilterBox" Margin="0,0,0,5" />
            <ScrollViewer Height="150">
                <ItemsControl Name="ElementosList"/>
            </ScrollViewer>
        </StackPanel>

        <!-- Fila 2: Botón -->
        <Button Grid.Row="2" Content="Aceptar" Width="100" Height="30"
                HorizontalAlignment="Center" Margin="0,20,0,0"
                Click="Aceptar_Click"/>
    </Grid>
</Window>

