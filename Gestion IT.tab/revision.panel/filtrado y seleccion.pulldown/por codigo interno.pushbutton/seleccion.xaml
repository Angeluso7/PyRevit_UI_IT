<Window 
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
  Title="Seleccionar Filtros" Height="150" Width="220" 
  WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <Grid>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
        <Button x:Name="btnAsignados" Content="Asignados" Width="180" Height="40" Margin="0,0,0,10" />
        <Button x:Name="btnNoAsignados" Content="No asignados" Width="180" Height="40" />
      </StackPanel>
    </Grid>
</Window>
